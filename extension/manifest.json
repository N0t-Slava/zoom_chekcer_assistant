{
  "manifest_version": 3,
  "name": "Zoom Attendance Tracker",
  "version": "0.1.0",
  "description": "Reads visible Zoom Web participants and sends attendance updates to a local FastAPI backend.",
  "host_permissions": ["https://*.zoom.us/*", "https://app.zoom.us/*", "http://127.0.0.1:8000/*", "http://localhost:8000/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.zoom.us/*", "https://app.zoom.us/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true,
      "match_about_blank": true
    }
  ]
}
